{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Karaoke",
  "version": "0.1.0",
  "identifier": "com.aikaraoke.app",
  "build": {
    "beforeDevCommand": "cd frontend && npm run dev",
    "devUrl": "http://localhost:43880",
    "beforeBuildCommand": "cd frontend && npm run build -- --mode tauri",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Karaoke",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: https://tauri.localhost; connect-src 'self' tauri: https://tauri.localhost http://localhost:18432; style-src 'unsafe-inline' 'self'; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/backend"],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
